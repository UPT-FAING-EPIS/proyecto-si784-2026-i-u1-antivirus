# .env.example
# Copia este archivo como .env y ajusta los valores a tu entorno local.
# El archivo .env real NO debe subirse al repositorio (ver .gitignore).

# Ruta al archivo SQLite de la base de datos
DB_PATH=antivirus.db

# Ruta a la carpeta de cuarentena
QUARANTINE_DIR=./quarantine

# Tamaño máximo de archivo a escanear (en MB)
MAX_FILE_SIZE_MB=100

# Versión del sistema
APP_VERSION=1.0.0
